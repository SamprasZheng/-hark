# Copy this file to .env and fill in real values.
# .env is .gitignored — never commit secrets.

# ─── Data APIs (Phase 2+) ────────────────────────────────────────────────
# Polygon.io — historical EOD + intraday (paid tier). Free tier exists for
# basic EOD; intraday during current day is NOT available on free tier.
# Sign up: https://polygon.io
POLYGON_API_KEY=

# Finnhub — news, earnings calendar, fundamentals. Generous free tier.
# Sign up: https://finnhub.io
FINNHUB_API_KEY=

# Finviz Elite — paid screener export with CSV. Free tier limits search results.
# We recommend the Elite tier ~$25/mo for Phase 2+ daily screener pulls.
FINVIZ_ELITE_API_KEY=

# yfinance — no key required.
# ccxt — no keys required for public market data only (which is what we use).

# ─── Mode configuration (Phase 3+) ───────────────────────────────────────
# Required for high-freq mode activation. Default: not set.
# See philosophy/07-mode-switch.md.
SHARKS_HIGH_FREQ_OK=
SHARKS_HIGH_FREQ_CRYPTO_OK=

# ─── LLM API (Phase 2+) ──────────────────────────────────────────────────
# For the Compiler / Researcher / Risk Officer agents.
ANTHROPIC_API_KEY=
# Optional fallback / extended-thinking model
OPENAI_API_KEY=

# ─── Notification (Phase 5+ dashboard) ───────────────────────────────────
# Optional: Telegram bot for daily output notification
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Logging ──────────────────────────────────────────────────────────────
SHARKS_LOG_LEVEL=INFO
