# Copy this file to .env and fill in real values.
# .env is .gitignored — never commit secrets.

# ─── Data APIs (Phase 2+) ────────────────────────────────────────────────
# Polygon.io — historical EOD + intraday (paid tier). Free tier exists for
# basic EOD; intraday during current day is NOT available on free tier.
# Sign up: https://polygon.io
POLYGON_API_KEY=

# Finnhub — news, earnings calendar, fundamentals. Generous free tier.
# Sign up: https://finnhub.io
FINNHUB_API_KEY=

# Finviz Elite — paid screener export with CSV. Free tier limits search results.
# We recommend the Elite tier ~$25/mo for Phase 2+ daily screener pulls.
# Token from Finviz: Account → API. Put it HERE in .env only (gitignored) — never
# commit it. Used by sharks.data.finviz_elite (the /export?...&auth=TOKEN client).
FINVIZ_ELITE_API_KEY=

# yfinance — no key required.
# ccxt — no keys required for public market data only (which is what we use).

# ─── Mode configuration (Phase 3+) ───────────────────────────────────────
# Required for high-freq mode activation. Default: not set.
# See philosophy/07-mode-switch.md.
SHARKS_HIGH_FREQ_OK=
SHARKS_HIGH_FREQ_CRYPTO_OK=

# ─── LLM API (Phase 2+) ──────────────────────────────────────────────────
# For the Compiler / Researcher / Risk Officer agents.
ANTHROPIC_API_KEY=
# Optional fallback / extended-thinking model
OPENAI_API_KEY=

# ─── Notification (Phase 5+ dashboard) ───────────────────────────────────
# Optional: Telegram bot for daily output notification
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Discord bot (src/sharks/discord/) ───────────────────────────────────
# Create the bot at https://discord.com/developers/applications (see
# src/sharks/discord/README.md). Token goes here; .env is .gitignored.
DISCORD_BOT_TOKEN=
# Optional: pin to one server. 0 / empty = use the single guild the bot is in.
DISCORD_GUILD_ID=

# Brain routing: hybrid (personas->Nemotron, /ask->Claude Code) | local | claude
SHARKS_DISCORD_BACKEND=hybrid
# /ask loopback (local Claude Code) — read-only research.
SHARKS_DISCORD_CLAUDE_MODEL=sonnet
SHARKS_DISCORD_CLAUDE_BUDGET_USD=0.50
SHARKS_DISCORD_CLAUDE_TIMEOUT_S=180
SHARKS_DISCORD_CLAUDE_BIN=
# Extra dirs Claude may read (besides cwd=$hark), os.pathsep-separated. Optional.
SHARKS_DISCORD_ADD_DIRS=

# Persona chat + council (local Ollama). Default to a clean instruct model —
# nemotron-3-nano:4b is a reasoning model that returns empty content when its
# budget is spent thinking. qwen2.5:7b answers 繁中 directly. /models lists live.
SHARKS_DISCORD_LOCAL_MODEL=qwen2.5:7b
SHARKS_DISCORD_DEFAULT_PERSONA=sharks
SHARKS_DISCORD_PERSONA_TEMP=0.6
SHARKS_DISCORD_PERSONA_MAXTOK=700

# Council debate (multi-persona 立場→交叉質詢→投票→結論, runs on the LOCAL model).
SHARKS_DISCORD_COUNCIL=1
SHARKS_DISCORD_COUNCIL_MODEL=
# 4 objective quant voices + KOL voices (供應鏈/總經狙擊/長線/底層邏輯/空方/動能).
# Add buffet,crypto for more KOLs (slower: each seat = ~3 local calls).
SHARKS_DISCORD_COUNCIL_PERSONAS=fomquant,bayes,valuation,regimequant,huang,serenity,sam,yupupin,bear,momentum
SHARKS_DISCORD_COUNCIL_CHAIR=sharks
# Per-seat models (round-robin). Keep to qwen2.5:7b + llama3.1:8b — both fit in
# 12 GB together so they stay resident (fast). /models lists what's pulled.
SHARKS_DISCORD_COUNCIL_MODELS=qwen2.5:7b,llama3.1:8b
# 交叉質詢 layer (1=立場→交叉質詢→投票→主席; 0=faster 質疑+投票 combined round).
SHARKS_DISCORD_COUNCIL_CROSSEXAM=1
# Closed loop: read recent 結論 + per-persona memory + topic RAG into each debate,
# and write the conclusion back to wiki/council/ (RAG-searchable; not auto-committed).
SHARKS_DISCORD_COUNCIL_MEMORY=1
SHARKS_DISCORD_COUNCIL_WRITEBACK=1

# Codex CLI backend for /llm (optional). Leave blank to auto-detect on PATH.
SHARKS_DISCORD_CODEX_BIN=

# Meetings (Taipei time, fixed UTC+8). 晨會/午會/晚會; weekly folds into Monday 晨會.
SHARKS_DISCORD_MEETINGS=1
SHARKS_DISCORD_MORNING=07:30
SHARKS_DISCORD_NOON=13:00
SHARKS_DISCORD_EVENING=22:30
SHARKS_DISCORD_WEEKLY_DAY=Monday
SHARKS_DISCORD_MEETING_REFRESH=1
SHARKS_DISCORD_MEETING_RESEARCH=1
SHARKS_DISCORD_VOICE=0

# ─── Logging ──────────────────────────────────────────────────────────────
SHARKS_LOG_LEVEL=INFO
