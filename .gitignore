# Cached / downloaded data — never commit raw market data
raw/market_data/*.csv
raw/market_data/*.parquet
!raw/market_data/.gitkeep

# Local data lake — price/info/news cache, regenerated from free APIs.
# Never commit (principal directive 2026-06-10: 導入本地數據不要 commit). Keep the dirs.
data/lake/prices/*.parquet
data/lake/info/*.json
data/lake/news/*
data/lake/world/*.json
data/lake/failed/*
data/lake/manifest.csv
!data/lake/prices/.gitkeep
