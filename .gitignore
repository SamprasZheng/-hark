# Trading-system specific
outputs/*.json
outputs/*.csv
outputs/*.jsonl
!outputs/.gitkeep

# Council debate conclusions — machine-generated dynamic state (like outputs/);
# regenerated each debate and may reference live views/positions. Keep the dir,
# not the notes (the human can curate/commit specific ones if wanted).
wiki/council/*.md
wiki/council/_history.jsonl
!wiki/council/.gitkeep

# Crypto tracker daily snapshots — immutable raw, regenerated each run (like outputs/).
# watchlist.yaml, watchlist_history/, and analysis/*.md stay tracked (point-in-time integrity).
crypto/data/*.json
!crypto/data/.gitkeep

# Cached / downloaded data — never commit raw market data
raw/market_data/*.csv
raw/market_data/*.parquet
!raw/market_data/.gitkeep

# Watchlist snapshots — committed in current form; history snapshots in
# Phase 2+ go to watchlist/history/ which IS tracked (point-in-time integrity)
# (no rule needed; they're kept)

# Temporary downloads / scratch
.scratch/
*.tmp
.karpathy-gist-raw.txt

# Derived OCR working copies of broker screenshots (originals kept as provenance)
raw/portfolio/_resized/
