!data/lake/info/.gitkeep
!data/lake/news/.gitkeep
!data/lake/world/.gitkeep
# Earnings + Discord-transcript caches (local only — cross-check / call-reduction / local-LLM)
data/earnings/*
data/transcripts/*
!data/earnings/.gitkeep
!data/transcripts/.gitkeep

